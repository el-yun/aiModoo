{
  "github": {
    "method": "cli",
    "owner": "el-yun",
    "repo": "aiModoo"
  },
  "trackers": {
    "primary": "github"
  },
  "linear": {
    "enabled": false
  },
  "notifications": {
    "enabled": false
  },
  "team": {
    "enabled": false
  },
  "permissions": {
    "scope": "write"
  },
  "review": {
    "autoApprove": false
  },
  "loop": {
    "mode": "tmux",
    "sessionName": "bylane-loops",
    "intervalMs": 300000
  },
  "workflow": {
    "maxRetries": 3,
    "loopTimeoutMinutes": 30
  },
  "figma": {
    "enabled": false
  },
  "branch": {
    "pattern": "{type}/{issue-number}-{title-slug}",
    "defaults": {
      "type": "feature",
      "tracker": "issues"
    }
  },
  "models": {
    "default": "claude-sonnet-4-6",
    "orchestrator": "claude-opus-4-6",
    "issue-agent": "claude-opus-4-6",
    "code-agent": "claude-sonnet-4-6",
    "test-agent": "claude-haiku-4-5-20251001",
    "commit-agent": "claude-haiku-4-5-20251001",
    "pr-agent": "claude-haiku-4-5-20251001",
    "review-agent": "claude-sonnet-4-6",
    "respond-agent": "claude-opus-4-6",
    "notify-agent": "claude-haiku-4-5-20251001"
  }
}
